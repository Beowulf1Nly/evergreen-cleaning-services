function showQuoteStep(step) {
  ['quoteStep1','quoteStep2','quoteStep3','quoteStep4','quoteSuccess'].forEach(id => {
    const el = document.getElementById(id); if(el) el.style.display='none';
  });
  // Update step dots + lines
  for (let i=1;i<=3;i++) {
    const dot = document.getElementById('sdot-'+i);
    if(dot) dot.className='quote-step-dot'+(i<step?' done':(i===step?' active':''));
  }
  [1,2].forEach(i => {
    const line=document.getElementById('sline-'+i);
    if(line) line.className='quote-step-line'+(i<step?' done':'');
  });
  const target = document.getElementById('quoteStep'+step) || document.getElementById('quoteSuccess');
  if (target) target.style.display = 'block';
  // Track current step for abandonment reporting
  _quoteCurrentStep = step;
  // Reset 15-min inactivity abandon timer on every step change
  if (_quoteAbandonTimer) clearTimeout(_quoteAbandonTimer);
  _quoteAbandonTimer = setTimeout(function() {
    var modal = document.getElementById('quoteModalOverlay');
    if (modal && modal.classList.contains('open')) {
      if (typeof trackEvt === 'function') trackEvt('/evt/quote_abandoned_step' + _quoteCurrentStep);
      closeQuoteModal();
    }
  }, 15 * 60 * 1000); // 15 minutes
  // Funnel analytics
  if (typeof trackEvt === 'function') {
    if (step === 3) trackEvt('/evt/quote_price_viewed');
    if (step === 4) trackEvt('/evt/quote_payment_step_reached');
  }
  // Mount Stripe card on step 4 — ensure Stripe.js is loaded first (it's lazy-loaded)
  if (step===4 && !stripeCardMounted) {
    initStripeElements().then(() => {
      if (stripeCardEl && !stripeCardMounted) {
        setTimeout(() => {
          stripeCardEl.mount('#q-card-element');
          stripeCardEl.on('change', ev => {
            const errEl=document.getElementById('q-card-errors');
            if(errEl) errEl.textContent = ev.error ? ev.error.message : '';
          });
          stripeCardMounted = true;
        }, 120);
      }
    }).catch(err => {
      const errEl=document.getElementById('q-card-errors');
      if(errEl) errEl.textContent = 'Could not load payment form. Please refresh and try again.';
    });
  }
}

