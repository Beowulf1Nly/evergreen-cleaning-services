async function runAnalyzingAnimation() {
  const fill   = document.getElementById('quoteProgressFill');
  const textEl = document.getElementById('q-analyzing-text');
  const steps  = [
    { pct:15, text:'Locating your property...' },
    { pct:42, text:'Scanning with satellite imagery...' },
    { pct:70, text:'Measuring your yard...' },
    { pct:90, text:'Calculating your price...' },
  ];
  // Show first step immediately so there's never a stale "Price calculated!" flash
  fill.style.transition = 'none';
  fill.style.width = '0%';
  textEl.textContent = steps[0].text;
  let i = 1;

  await new Promise(resolve => {
    const iv = setInterval(() => {
      if (i >= steps.length) { clearInterval(iv); resolve(); return; }
      fill.style.transition = 'width 0.55s ease';
      fill.style.width = steps[i].pct + '%';
      textEl.textContent = steps[i].text;
      i++;
    }, 600);
  });

  // Wait up to 8s for the lot size lookup — covers slow geocode + multiple ArcGIS retries.
  // This prevents step 3 from appearing with stale/default pricing when the lookup takes 5+ sec.
  if (_lotLookupPromise) {
    textEl.textContent = 'Finalizing your quote...';
    fill.style.transition = 'width 4s ease';
    fill.style.width = '96%';
    try { await Promise.race([_lotLookupPromise, new Promise(r => setTimeout(r, 8000))]); } catch(e) {}
  }

  fill.style.transition = 'width 0.35s ease';
  fill.style.width = '100%';
  textEl.textContent = 'Price calculated! ✓';
  setTimeout(() => { buildStep3(); showQuoteStep(3); initQCal(); }, 420);
}

