  const tierKey   = LOT_TIERS[qState.lotTierIdx] ? LOT_TIERS[qState.lotTierIdx].key : 'xl';
  const prices    = PLAN_PRICING[tierKey] || { biweekly: null, weekly: null };
  const isXL      = tierKey === 'xl' || (prices.biweekly === null && prices.weekly === null);
  const planId    = qState.selectedPlan;
  const dateFmt   = new Date(qState.startDate+'T12:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'});

  // Show/hide payment vs XL sections
  const paySection = document.getElementById('q-payment-section');
  const xlSection  = document.getElementById('q-xl-section');
  if (paySection) paySection.style.display = isXL ? 'none' : 'block';
  if (xlSection)  xlSection.style.display  = isXL ? 'block' : 'none';

  if (isXL) {
    const timePref = qState.preferredTime || 'Not specified';
    document.getElementById('quoteOrderSummary').innerHTML =
      '<div class="quote-order-row"><span>Visit Type</span><span style="font-weight:600;color:var(--green-deep)">Free On-Site Quote</span></div>' +
      '<div class="quote-order-row"><span>Date Requested</span><span style="font-weight:600;color:var(--green-deep)">' + dateFmt + '</span></div>' +
      '<div class="quote-order-row"><span>Preferred Time</span><span style="font-weight:600;color:var(--green-deep)">' + timePref + '</span></div>' +
      '<div class="quote-order-total"><span>Cost</span><span class="quote-order-amount" style="font-size:18px;">FREE</span></div>';
    return;
  }

  const planNames = {'biweekly':'Bi-Weekly Plan','weekly':'Weekly Plan'};
  const after      = prices[planId];
  const isRet      = qState.isReturning || false;
  const promoPrice = getPromoPrice(qState.lotTierIdx);
  const showPromo  = !isRet && promoPrice !== null;
  const afterTxt   = !after ? 'Custom quote' : '$' + after + '/mow';
  const todayAmt   = showPromo ? '$' + promoPrice : (after ? '$' + after : 'Custom');
  const todayLbl   = showPromo ? 'Charged after first service' : 'Per mow';

  // Update pay button text to match
  const payText = document.querySelector('#q-pay-btn .pay-text');
  if (payText) {
    payText.textContent = showPromo
      ? '🔒 Book Now — $' + promoPrice + ' Charged After First Mow'
      : '🔒 Book Now — ' + (after ? '$' + after + ' per mow' : 'Request Custom Quote');
  }

  document.getElementById('q-following-line').textContent = showPromo
    ? 'Following services: ' + afterTxt
    : 'Per mow: ' + afterTxt;
  document.getElementById('quoteOrderSummary').innerHTML =
    '<div class="quote-order-row"><span>Service</span><span style="font-weight:600;color:var(--green-deep)">' + planNames[planId] + '</span></div>' +
    '<div class="quote-order-row"><span>Start Date</span><span style="font-weight:600;color:var(--green-deep)">' + dateFmt + '</span></div>' +
    (showPromo ? '<div class="quote-order-row"><span>Following services</span><span style="color:var(--green-mid);font-weight:600">' + afterTxt + '</span></div>' : '') +
    '<div class="quote-order-total"><span>' + todayLbl + '</span><span class="quote-order-amount">' + todayAmt + '</span></div>';
}

// ── STEP 4 — Payment ──
async function quotePaySubmit() {
  // Funnel analytics — track payment attempt
  if (typeof trackEvt === 'function') trackEvt('/evt/payment_attempted');
  // Collect contact info entered on step 4
  const name    = (document.getElementById('q-name')?.value || '').trim();
  const email   = (document.getElementById('q-email')?.value || '').trim();
  const phone   = (document.getElementById('q-phone')?.value || '').trim();
  const contactErrEl = document.getElementById('q-contact-error');
  if (!name) {
    if (contactErrEl) { contactErrEl.textContent='Please enter your full name.'; contactErrEl.style.display='block'; }
    return;
  }
  if (!email || !email.includes('@') || !email.includes('.')) {
    if (contactErrEl) { contactErrEl.textContent='Please enter a valid email address.'; contactErrEl.style.display='block'; }
    return;
  }
  if (contactErrEl) contactErrEl.style.display='none';
  qState.name=name; qState.email=email; qState.phone=phone;

  // Disable button IMMEDIATELY — prevents double-submit if user clicks twice
  const btn   = document.getElementById('q-pay-btn');
  const errEl = document.getElementById('q-card-errors');
  btn.classList.add('loading'); btn.disabled=true; errEl.textContent='';

  // Check if returning customer now that we have their email
  try {
    const ctrl = new AbortController();
    const tId  = setTimeout(() => ctrl.abort(), 4000);
    const res  = await fetch(SHEETS_SCRIPT_URL + '?action=check_customer&email=' + encodeURIComponent(email), { signal: ctrl.signal });
    clearTimeout(tId);
    const data = await res.json();
    qState.isReturning = data.success && data.isExisting;
  } catch(e) { qState.isReturning = false; }

  try {
    const tierKey    = LOT_TIERS[qState.lotTierIdx].key;
    const prices     = PLAN_PRICING[tierKey];
    const planId     = qState.selectedPlan;
    const planNames  = {'biweekly':'Bi-Weekly Plan','weekly':'Weekly Plan'};
    const freqLabels = {'biweekly':'Bi-Weekly Plan','weekly':'Weekly Plan'};
    const dayValues  = {'biweekly':14,'weekly':7};
    const afterPrice = prices[planId] || 'custom';
    const dateFmt    = new Date(qState.startDate+'T12:00:00').toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
    const isReturning = qState.isReturning || false;

    const intentParams = new URLSearchParams({
      action: 'booking_create_intent',
      email:  qState.email,
      name:   qState.name,
    });
    let clientSecret='', customerId='';
    try {
      const res  = await fetch(SHEETS_SCRIPT_URL+'?'+intentParams.toString());
      const data = await res.json();
      if (!data.success) throw new Error(data.error || 'Could not set up card');
      clientSecret = data.clientSecret;
      customerId   = data.customerId;
    } catch(fetchErr) {
      throw new Error('Could not reach payment server. Please call (352) 462-0627.');
    }

    qState.stripeCustomerId = customerId;

    const { setupIntent, error } = await stripeInstance.confirmCardSetup(clientSecret, {
      payment_method: {
        card: stripeCardEl,
        billing_details: { name: qState.name, email: qState.email, phone: qState.phone },
      },
    });

    if (error) {
      errEl.textContent = error.message;
      btn.classList.remove('loading'); btn.disabled=false; return;
    }

    const completeParams = new URLSearchParams({
      action:           'booking_complete',
      pmId:             setupIntent.payment_method,
      stripeCustomerId: customerId,
      name:             qState.name,
      email:            qState.email,
      phone:            qState.phone,
      address:          qState.address,
      zip:              qState.zip,
      service:          planNames[planId],
      frequency:        freqLabels[planId],
      days:             dayValues[planId] || 0,
      followingPrice:   String(afterPrice),
      serviceDateRaw:   qState.startDate,
      serviceDate:      dateFmt,
      yardSize:         tierKey,
      ref:              document.referrer ? (function(){ try { return new URL(document.referrer).hostname; } catch(e){ return document.referrer; } })() : 'direct',
      notes:            isReturning
        ? 'Returning customer. Per-mow rate: ' + afterPrice
        : 'First service $19 promo. Following: ' + afterPrice,
    });
    fetch(SHEETS_SCRIPT_URL+'?'+completeParams.toString(), { method:'GET', mode:'no-cors' }).catch(()=>{});

    btn.classList.remove('loading'); btn.disabled=false;

    // ── Fire Google Ads conversion (booking confirmed) ──────────────
    gtag_report_conversion();

    document.getElementById('q-success-date').textContent =
      new Date(qState.startDate+'T12:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'});
    document.getElementById('quoteStepsBar').style.display='none';
    ['quoteStep1','quoteStep2','quoteStep3','quoteStep4'].forEach(id=>{
      const el=document.getElementById(id); if(el) el.style.display='none';
    });
    // Mark as converted so closeQuoteModal() doesn't fire an abandonment event
    _quoteCurrentStep = 0;
    if (_quoteAbandonTimer) { clearTimeout(_quoteAbandonTimer); _quoteAbandonTimer = null; }
    document.getElementById('quoteSuccess').style.display='block';
  } catch(err) {
    errEl.textContent = err.message || 'Something went wrong. Please call (352) 462-0627.';
    btn.classList.remove('loading'); btn.disabled=false;
  }
}

// ═══════════════════════════════════════════════════════════════
// ANALYTICS TRACKER — no 3rd party, stores in Google Sheets
// Tracks: scroll depth, section time, hover exits, exit intent,
//         CTA clicks, conversion funnel events
// ═══════════════════════════════════════════════════════════════
(function() {
  // Visitor ID — persists across sessions
  if (!localStorage.getItem('eg_vid')) {
    localStorage.setItem('eg_vid', Math.random().toString(36).slice(2) + Date.now().toString(36));
  }

  const ANA = {
    startTime:        Date.now(),
    maxScroll:        0,
    scrollMilestones: [],
    sectionsViewed:   new Set(),
    sectionTimes:     {},   // id → cumulative ms in view
    _sectionEntry:    {},   // id → timestamp of current entry
    ctaClicks:        [],
    hoverExits:       [],   // label@Xs — hovered key element then left without clicking
    exitIntent:       false,
    exitSection:      '',
    device:           window.innerWidth <= 768 ? 'mobile' : 'desktop',
    referrer:         document.referrer ? (function(){ try { return new URL(document.referrer).hostname; } catch(e){ return document.referrer; }})() : 'direct',
    sent:             false,
  };

  // ── Scroll depth ──────────────────────────────────────────────
  function updateScroll() {
    const total = document.body.scrollHeight - window.innerHeight;
    if (total <= 0) return;
    const pct = Math.round((window.scrollY / total) * 100);
    if (pct > ANA.maxScroll) ANA.maxScroll = pct;
    [25, 50, 75, 90, 100].forEach(function(m) {
      if (pct >= m && ANA.scrollMilestones.indexOf(m) === -1) ANA.scrollMilestones.push(m);
    });
  }
  window.addEventListener('scroll', updateScroll, { passive: true });

  // ── Section enter/exit ────────────────────────────────────────
  const TRACKED_IDS = ['hero', 'services', 'how', 'trust', 'faq', 'service-areas'];

  function onSectionEnter(id) {
    if (!id) return;
    ANA.sectionsViewed.add(id);
    ANA.exitSection = id;
    if (!ANA._sectionEntry[id]) ANA._sectionEntry[id] = Date.now();
  }
  function onSectionExit(id) {
    if (!id || !ANA._sectionEntry[id]) return;
    ANA.sectionTimes[id] = (ANA.sectionTimes[id] || 0) + (Date.now() - ANA._sectionEntry[id]);
    delete ANA._sectionEntry[id];
  }

  const sectionIo = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      var id = e.target.id || e.target.dataset.anaId;
      if (e.isIntersecting) { onSectionEnter(id); }
      else                  { onSectionExit(id);  }
    });
  }, { threshold: 0.25 });

  document.addEventListener('DOMContentLoaded', function() {
    TRACKED_IDS.forEach(function(id) {
      var el = document.getElementById(id);
      if (el) sectionIo.observe(el);
    });
    // Hero is above the fold — mark entered immediately
    var hero = document.querySelector('.hero');
    if (hero) {
      if (!hero.id) hero.id = 'hero';
      sectionIo.observe(hero);
      onSectionEnter('hero');
    }

    // ── Hover exit tracking ───────────────────────────────────
    // Key conversion elements: hover + leave without clicking = "looked but left"
    var HOVER_TARGETS = [
      { sel: '.btn-primary, .nav-cta',              label: 'cta_btn'      },
      { sel: '[onclick*="openQuoteModal"]',          label: 'quote_cta'    },
      { sel: '.quote-plan-card',                    label: 'plan_card'    },
      { sel: '.service-card',                       label: 'service_card' },
      { sel: '#promoBanner',                        label: 'promo_banner' },
    ];
    HOVER_TARGETS.forEach(function(t) {
      document.querySelectorAll(t.sel).forEach(function(el) {
        var enterTime = 0;
        var clicked   = false;
        el.addEventListener('mouseenter', function() { enterTime = Date.now(); clicked = false; });
        el.addEventListener('click',      function() { clicked = true; });
        el.addEventListener('mouseleave', function() {
          if (enterTime && !clicked && (Date.now() - enterTime) > 400) {
            // Genuine look-and-leave (not just mouse passing through)
            ANA.hoverExits.push(t.label + '@' + Math.round((Date.now() - ANA.startTime) / 1000) + 's');
          }
          enterTime = 0; clicked = false;
        });
      });
    });

    // ── Exit intent — cursor leaving toward top of browser ────
    // Popup fires after 12s on page; once per session; desktop only
    var _exitPopupShown = !!sessionStorage.getItem('eg_exit_shown');
    var _exitPopupArmed = false;
    setTimeout(function() { _exitPopupArmed = true; }, 12000);

    document.addEventListener('mouseleave', function(e) {
      if (e.clientY > 5) return;            // must be heading toward top bar
      ANA.exitIntent = true;                // always log for analytics
      if (_exitPopupShown)       return;    // already shown this session
      if (!_exitPopupArmed)      return;    // page loaded less than 12s ago
      if (window.innerWidth < 768) return;  // no cursor on mobile
      if (document.querySelector('.modal-overlay.open')) return; // modal already up
      _exitPopupShown = true;
      sessionStorage.setItem('eg_exit_shown', '1');
      showExitPopup();
    });

    // ── CTA click patching ────────────────────────────────────
    var origOpenQuoteModal = window.openQuoteModal;
    if (origOpenQuoteModal) {
      window.openQuoteModal = function() {
        ANA.ctaClicks.push('quote_modal@' + Math.round((Date.now() - ANA.startTime) / 1000) + 's');
        return origOpenQuoteModal.apply(this, arguments);
      };
    }
    var origOpenModal = window.openModal;
    if (origOpenModal) {
      window.openModal = function() {
        ANA.ctaClicks.push('book_modal@' + Math.round((Date.now() - ANA.startTime) / 1000) + 's');
        return origOpenModal.apply(this, arguments);
      };
    }
    document.querySelectorAll('[href^="tel:"]').forEach(function(el) {
      el.addEventListener('click', function() {
        ANA.ctaClicks.push('phone@' + Math.round((Date.now() - ANA.startTime) / 1000) + 's');
      });
    });
    document.querySelectorAll('[href="/free-lawn"], [href*="free-lawn"]').forEach(function(el) {
      el.addEventListener('click', function() {
        ANA.ctaClicks.push('free_lawn@' + Math.round((Date.now() - ANA.startTime) / 1000) + 's');
      });
    });
  });

  // ── Flush open section timers before sending ──────────────────
  function flushSectionTimers() {
    Object.keys(ANA._sectionEntry).forEach(function(id) {
      ANA.sectionTimes[id] = (ANA.sectionTimes[id] || 0) + (Date.now() - ANA._sectionEntry[id]);
      delete ANA._sectionEntry[id];
    });
  }

  function sectionTimesStr() {
    flushSectionTimers();
    return Object.keys(ANA.sectionTimes).map(function(id) {
      return id + ':' + Math.round(ANA.sectionTimes[id] / 1000) + 's';
    }).join(',');
  }

  // ── Send engagement snapshot on page exit ─────────────────────
  function sendAnalytics() {
    if (ANA.sent) return;
    ANA.sent = true;
    try {
      var vid = localStorage.getItem('eg_vid') || '';
      var BLOCKED_VIDS = ['p11aykzdd0hmorg0xgv', 'iq05eltt3jmoq03373'];
      if (BLOCKED_VIDS.indexOf(vid) !== -1) return;
      var p = new URLSearchParams({
        action:        'analytics',
        page:          location.pathname,
        device:        ANA.device,
        ref:           ANA.referrer,
        time_s:        Math.round((Date.now() - ANA.startTime) / 1000),
        max_scroll:    ANA.maxScroll,
        milestones:    ANA.scrollMilestones.join(','),
        sections:      Array.from(ANA.sectionsViewed).join(','),
        section_times: sectionTimesStr(),
        ctas:          ANA.ctaClicks.join('|'),
        hover_exits:   ANA.hoverExits.join('|'),
        exit_intent:   ANA.exitIntent ? '1' : '0',
        exit:          ANA.exitSection,
        screen_w:      window.innerWidth,
        vid:           vid,
      });
      var url = SHEETS_SCRIPT_URL + '?' + p.toString();
      // IMPORTANT: Apps Script URLs redirect. sendBeacon does NOT follow redirects
      // and silently drops the request. Use fetch GET (no-cors follows redirects,
      // keepalive: true survives page unload). Same pattern as working trackEvt calls.
      fetch(url, { method: 'GET', mode: 'no-cors', keepalive: true }).catch(function(){});
    } catch(err) { /* silent */ }
  }

  document.addEventListener('visibilitychange', function() {
    if (document.visibilityState === 'hidden') sendAnalytics();
  });
  window.addEventListener('pagehide',      sendAnalytics);
  window.addEventListener('beforeunload',  sendAnalytics);

  // Expose for external access (e.g. quote funnel can read ANA.exitIntent)
  window._ANA = ANA;

})();

