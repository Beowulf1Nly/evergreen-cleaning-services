// ── Services section photo strip ──────────────────────────────
function initSvcStrip() {
  var strip = document.getElementById('svcPhotoStrip');
  var dots  = document.getElementById('svcPhotoDots');
  if (!strip || !carouselData.images || !carouselData.images.length) return;

  var imgs    = carouselData.images;
  var current = 0;
  window._svcCurrent = 0;
  window._svcTotal   = imgs.length;
  var imgEls;

  strip.innerHTML = imgs.map(function(src, i) {
    return '<img src="' + src + '" alt="Lawn photo ' + (i+1) + '" loading="' + (i===0?'eager':'lazy') + '" ' +
      'style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;' +
      'opacity:' + (i===0?'1':'0') + ';transition:opacity 0.9s ease;" />';
  }).join('');

  dots.innerHTML = imgs.map(function(_, i) {
    return '<div style="width:' + (i===0?'20':'8') + 'px;height:8px;border-radius:4px;background:' +
      (i===0?'#fff':'rgba(255,255,255,0.45)') + ';transition:all 0.3s ease;cursor:pointer;" onclick="svcGoTo(' + i + ')"></div>';
  }).join('');

  imgEls = strip.querySelectorAll('img');

  // Click strip to open lightbox
  strip.addEventListener('click', function() { openLightbox(current); });

  // Auto-advance timer — stored so manual navigation can reset it
  // Uses setTimeout (not setInterval) so each advance schedules exactly one future slide,
  // preventing a stale tick from firing immediately after a manual swipe.
  var svcTimer = null;
  function resetSvcTimer() {
    clearTimeout(svcTimer);
    svcTimer = setTimeout(function() {
      window.svcGoTo((current + 1) % imgs.length);
    }, 4500);
  }

  window.svcGoTo = function(idx) {
    var dotEls = dots.children;
    dotEls[current].style.width = '8px';
    dotEls[current].style.background = 'rgba(255,255,255,0.45)';
    imgEls[current].style.opacity = '0';
    current = idx;
    window._svcCurrent = idx;
    imgEls[current].style.opacity = '1';
    dotEls[current].style.width = '20px';
    dotEls[current].style.background = '#fff';
    resetSvcTimer(); // Reset auto-advance so it doesn't fire immediately after a manual swipe
  };

  resetSvcTimer(); // Start auto-advance

  // Lightbox
  window.openLightbox = function(idx) {
    var lb = document.getElementById('svcLightbox');
    var lbImg = document.getElementById('svcLightboxImg');
    var lbCounter = document.getElementById('svcLightboxCounter');
    if (!lb || !lbImg) return;
    lbImg.src = imgs[idx];
    lbCounter.textContent = (idx + 1) + ' / ' + imgs.length;
    lb._idx = idx;
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  };
  window.closeLightbox = function() {
    var lb = document.getElementById('svcLightbox');
    if (lb) { lb.style.display = 'none'; document.body.style.overflow = ''; }
  };
  window.lightboxNav = function(dir) {
    var lb = document.getElementById('svcLightbox');
    if (!lb) return;
    var idx = ((lb._idx || 0) + dir + imgs.length) % imgs.length;
    openLightbox(idx);
  };
  // Keyboard nav
  document.addEventListener('keydown', function(e) {
    var lb = document.getElementById('svcLightbox');
    if (!lb || lb.style.display === 'none') return;
    if (e.key === 'ArrowRight') lightboxNav(1);
    if (e.key === 'ArrowLeft')  lightboxNav(-1);
    if (e.key === 'Escape')     closeLightbox();
  });
}

// ── Photo Grid (replaces old carousel) ────────────────────────
function initPhotoGrid() {
  const grid = document.getElementById('photoGrid');
  if (!grid) return;
  if (!carouselData.images || carouselData.images.length === 0) return;

  const imgs = carouselData.images;
  // Build grid: first image spans 2 rows (tall) on the left, rest fill right
  grid.innerHTML = imgs.map((src, i) => {
    const span = (i === 0) ? 'grid-row:span 2;' : '';
    return `<div style="${span}overflow:hidden;border-radius:12px;aspect-ratio:${i===0?'4/5':'4/3'};">
      <img src="${src}" alt="Lawn care photo ${i+1}" loading="${i===0?'eager':'lazy'}" decoding="async"
           style="width:100%;height:100%;object-fit:cover;transition:transform .4s ease;"
           onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'"/>
    </div>`;
  }).join('');

  // Responsive: stack to 2-col on tablet, 1-col on mobile
  function applyGrid() {
    const w = window.innerWidth;
    grid.style.gridTemplateColumns = w < 600 ? '1fr' : w < 900 ? 'repeat(2,1fr)' : 'repeat(3,1fr)';
  }
  applyGrid();
  window.addEventListener('resize', applyGrid);
}

