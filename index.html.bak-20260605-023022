// ── Mobile hamburger menu ─────────────────────────────────────────────────
function toggleMobileMenu() {
  var btn = document.getElementById('navHamburger');
  var nav = document.getElementById('mobileNav');
  var isOpen = nav.classList.toggle('open');
  btn.classList.toggle('open', isOpen);
  btn.setAttribute('aria-expanded', String(isOpen));
}
function closeMobileMenu() {
  var m = document.getElementById('mobileNav');
  var b = document.getElementById('navHamburger');
  if (m) m.classList.remove('open');
  if (b) { b.classList.remove('open'); b.setAttribute('aria-expanded', 'false'); }
}

// ── Page view tracker ─────────────────────────────────────────────────────
// Fires once per page load. Bot filter: requires a human signal within 4s.
(function() {
  if (!localStorage.getItem('eg_vid')) {
    localStorage.setItem('eg_vid', Math.random().toString(36).slice(2) + Date.now().toString(36));
  }
  var fired = false;
  function firePageView() {
    if (fired) return;
    fired = true;
    if (typeof trackEvt === 'function') trackEvt(location.pathname);
  }
  // Human signal: scroll, click, touch, or keypress
  ['scroll','click','touchstart','keydown'].forEach(function(ev) {
    window.addEventListener(ev, firePageView, { once: true, passive: true });
  });
  // Fallback: fire after 4s for engaged-but-still readers
  setTimeout(firePageView, 4000);
})();

