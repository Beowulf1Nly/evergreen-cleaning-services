async function lookupLotSize(address, zip) {
  qState.lotAutoDetected = false;
  qState.lotEstimated    = false;
  qState.detectedAcreage = null;
  qState.lotTierIdx      = 0; // default to Small (cheapest) if detection fails

  // ── Step 1: Geocode with Nominatim (with 1 retry for rate-limit flakiness) ─
  let lat = null, lon = null;
  async function nominatimGeocode(q) {
    const r = await fetch(
      'https://nominatim.openstreetmap.org/search?q=' + encodeURIComponent(q)
        + '&format=json&limit=1&countrycodes=us',
      { headers: { 'Accept': 'application/json' } }
    );
    const d = await r.json();
    return (d && d.length > 0) ? d[0] : null;
  }
  try {
    const query = address + (zip ? ', FL ' + zip : '') + ', US';
    let hit = await nominatimGeocode(query);
    if (!hit) {
      // Brief pause then retry (handles Nominatim rate-limit blips)
      await new Promise(r => setTimeout(r, 1200));
      hit = await nominatimGeocode(query);
    }
    if (hit) {
      lat = parseFloat(hit.lat);
      lon = parseFloat(hit.lon);
    }
  } catch(eGeo) {}

  // ── Step 2: Florida Statewide Cadastral (ArcGIS Online — CORS enabled) ─
  const FL_CADASTRAL = 'https://services9.arcgis.com/Gh9awoU677aKree0/arcgis/rest/services/Florida_Statewide_Cadastral/FeatureServer/0/query';

  // Extract house number from address once — used for parcel matching
  const houseNum = address.trim().split(/\s+/)[0] || '';

  // Read acreage from a single ArcGIS attributes object.
  // Tries direct acreage fields first, then sqft → acres, then shape area.
  function sqftToAcres(a) {
    const ac = parseFloat(a.CALC_ACRES || a.GIS_ACRES || a.ACRES || a.ACREAGE || a.TOT_ACRES || a.PARCEL_ACRES || 0);
    if (ac > 0) return ac;
    const sqft = parseFloat(a.LND_SQFOOT || a.LAND_SQFOOT || a.CALC_SQFOOT || a.LAND_SF || a.LOT_SIZE || a.SQFOOTAGE || 0);
    if (sqft > 100) return sqft / 43560;
    // Florida Statewide Cadastral uses State Plane FL (feet), so Shape__Area is sq ft
    const shapeSqft = parseFloat(a.Shape__Area || a.SHAPE_Area || 0);
    if (shapeSqft > 100) return shapeSqft / 43560;
    return 0;
  }

  // Given a list of parcel attribute objects, return the best one:
  //   1. Prefer a parcel whose PHY_ADDR1 starts with the user's house number
  //   2. Otherwise pick the parcel with the largest acreage
  //      (road strips / easements are always smaller than the residential lot)
  function pickBestParcel(features) {
    if (!features || features.length === 0) return null;
    const attrs = features.map(f => f.attributes);
    if (attrs.length === 1) return attrs[0];
    // Address match takes priority
    if (houseNum) {
      const match = attrs.filter(a => String(a.PHY_ADDR1 || a.SITE_ADDR || '').trim().startsWith(houseNum));
      if (match.length > 0) return match.reduce((b, a) => sqftToAcres(a) > sqftToAcres(b) ? a : b, match[0]);
    }
    // Fall back to largest acreage
    return attrs.reduce((b, a) => sqftToAcres(a) > sqftToAcres(b) ? a : b, attrs[0]);
  }

  async function cadastralQuery(params) {
    const qs = Object.entries(params).map(([k,v]) => k + '=' + encodeURIComponent(v)).join('&');
    try {
      const res  = await fetch(FL_CADASTRAL + '?' + qs);
      const data = await res.json();
      if (data.features && data.features.length > 0) return pickBestParcel(data.features);
      return null;
    } catch(e) { return null; }
  }

  if (lat && lon) {
    let attrs = null;

    // 2a — 100m buffer: reliably intersects the parcel even when Nominatim
    //      geocodes to the road edge. Return up to 5 features so pickBestParcel
    //      can choose the residential lot over any road strip / easement.
    if (!attrs) {
      try {
        attrs = await cadastralQuery({
          where: '1=1',
          geometry: JSON.stringify({ x: lon, y: lat, spatialReference: { wkid: 4326 } }),
          geometryType: 'esriGeometryPoint',
          inSR: '4326', spatialRel: 'esriSpatialRelIntersects',
          distance: '100', units: 'esriSRUnit_Meter',
          outFields: '*', returnGeometry: 'false', f: 'json'
        });
      } catch(e) {}
    }

    // 2b — 250m retry for large/rural lots or off-centre geocodes
    if (!attrs) {
      try {
        attrs = await cadastralQuery({
          where: '1=1',
          geometry: JSON.stringify({ x: lon, y: lat, spatialReference: { wkid: 4326 } }),
          geometryType: 'esriGeometryPoint',
          inSR: '4326', spatialRel: 'esriSpatialRelIntersects',
          distance: '250', units: 'esriSRUnit_Meter',
          outFields: '*', returnGeometry: 'false', f: 'json'
        });
      } catch(e) {}
    }

    // 2c — Address text query fallback
    if (!attrs) {
      try {
        const cleanAddr  = address.replace(/,.*/, '').trim().toUpperCase().replace(/'/g, "''");
        const parts      = cleanAddr.split(/\s+/);
        const hn         = parts[0];
        const streetPart = parts.slice(1).join(' ');
        const whereHouse  = `PHY_ADDR1 LIKE '${hn}%${streetPart}%'`;
        const whereStreet = `PHY_ADDR1 LIKE '%${streetPart}%'`;
        attrs = await cadastralQuery({ where: whereHouse, outFields: '*', returnGeometry: 'false', f: 'json' });
        if (!attrs) attrs = await cadastralQuery({ where: whereStreet, outFields: '*', returnGeometry: 'false', f: 'json' });
      } catch(e) {}
    }

    if (attrs) {
      const acres = sqftToAcres(attrs);
      if (acres > 0) {
        qState.detectedAcreage = Math.round(acres * 100) / 100;
        qState.lotTierIdx      = acreageToTierIdx(acres);
        qState.lotAutoDetected = true;
        qState.lotEstimated    = false;
        return;
      }
    }
  }

  // ── Step 3: Apps Script fallback ─────────────────────────────────────
  try {
    const url  = SHEETS_SCRIPT_URL + '?action=lookup_lot_size&address='
      + encodeURIComponent(address + (zip ? ', FL ' + zip : ''));
    const res  = await fetch(url);
    const data = await res.json();
    if (data.success && typeof data.tierIdx === 'number') {
      qState.lotTierIdx      = data.tierIdx;
      qState.detectedAcreage = data.acreage || null;
      qState.lotAutoDetected = true;
      qState.lotEstimated    = !!data.estimated;
      return;
    }
  } catch(eScript) {}

  // ── Step 4: ZIP fallback ─────────────────────────────────────────────
  // Tier indices: 0=small(<¼ac) 1=medium(¼-½) 2=threequarter(½-¾) 3=one(¾-1) 4=xl(>1/free quote)
  const ZIP_TIERS = {
    // Citrus County
    '34428':1,'34429':1,
    '34450':1,'34451':1,'34452':1,'34453':1,
    '34446':2,'34447':2,'34448':2,
    '34460':1,'34461':2,
    '34433':2,'34434':1,
    '34436':2,
    '34442':1,
    '34449':2,'34498':2,
    '34464':1,'34465':1,
    // Marion County
    '34431':2,'34432':2,
    '34470':1,'34471':1,'34472':1,'34473':2,
    '34474':1,'34475':1,'34476':1,'34479':1,
    '34480':1,'34481':2,'34482':2,
    '34488':2,'34489':2,'34491':2,
    // Levy County
    '32621':2,'32626':2,'32668':2,'32693':2,
    // Hernando County
    '34601':1,'34602':1,'34604':2,
    '34606':1,'34607':2,'34608':1,'34609':1,
    '34613':2,'34614':2,
    // Sumter County
    '33514':2,'33538':2,'33585':2,
  };
  if (zip && ZIP_TIERS[zip] !== undefined) {
    qState.lotTierIdx      = ZIP_TIERS[zip];
    qState.lotAutoDetected = true;
    qState.lotEstimated    = true;
  }
}

