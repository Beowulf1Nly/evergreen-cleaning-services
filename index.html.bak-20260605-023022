  if (overlay) {
    overlay.addEventListener('mousedown', function(e) {
      if (e.target === overlay) closeExitPopup();
    });
  }
});


// ── Event tracker — quote funnel + conversion events ─────────────────────
// Called throughout the quote flow: quote_opened, price_viewed, payment_attempted, etc.
function trackEvt(evtPage) {
  try {
    var vid = localStorage.getItem('eg_vid') || '';
    var BLOCKED_VIDS = ['p11aykzdd0hmorg0xgv', 'iq05eltt3jmoq03373'];
    if (BLOCKED_VIDS.indexOf(vid) !== -1) return;
    var ref = 'direct';
    try { if (document.referrer) ref = new URL(document.referrer).hostname; } catch(e){}
    var p = new URLSearchParams({
      action: 'track_visit',
      page:   evtPage,
      ref:    ref,
      ua:     navigator.userAgent.substring(0, 200),
      vid:    vid,
    });
    var url = SHEETS_SCRIPT_URL + '?' + p.toString();
    // fetch GET no-cors follows Apps Script redirects; sendBeacon does not
    fetch(url, { method: 'GET', mode: 'no-cors' }).catch(function(){});
  } catch(err) { /* silent */ }
}

