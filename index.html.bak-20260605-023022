<script>
// ─────────────────────────────────────────────
// BOOKING CALENDAR CONFIG
// ─────────────────────────────────────────────
const MAX_BOOKING_DAYS = 30; // how many days out customers can book
const MIN_BOOKING_DAYS = 1;  // earliest bookable day (1 = tomorrow).

// Dates to block (format: 'YYYY-MM-DD'). Add/remove as needed.
const BLOCKED_DATES = new Set([
  // ── 2026 Federal Holidays ──
  '2026-01-01', // New Year's Day
  '2026-01-19', // MLK Day
  '2026-02-16', // Presidents' Day
  '2026-05-25', // Memorial Day
  '2026-06-19', // Juneteenth
  '2026-07-03', // Independence Day (observed, July 4 falls on Sat)
  '2026-07-04', // Independence Day
  '2026-09-07', // Labor Day
  '2026-10-12', // Columbus Day
  '2026-11-11', // Veterans Day
  '2026-11-26', // Thanksgiving
  '2026-11-27', // Day after Thanksgiving
  '2026-12-24', // Christmas Eve
  '2026-12-25', // Christmas Day
  '2026-12-31', // New Year's Eve
  // ── 2027 Federal Holidays ──
  '2027-01-01', // New Year's Day
  '2027-01-18', // MLK Day
  '2027-02-15', // Presidents' Day
  '2027-05-31', // Memorial Day
  '2027-06-18', // Juneteenth (observed, June 19 falls on Sat)
  '2027-06-19', // Juneteenth
  '2027-07-04', // Independence Day (Sun)
  '2027-07-05', // Independence Day (observed)
  '2027-09-06', // Labor Day
  '2027-10-11', // Columbus Day
  '2027-11-11', // Veterans Day
  '2027-11-25', // Thanksgiving
  '2027-11-26', // Day after Thanksgiving
  '2027-12-24', // Christmas Eve
  '2027-12-25', // Christmas Day
  '2027-12-31', // New Year's Eve
]);

// ─────────────────────────────────────────────
// CALENDAR STATE + FUNCTIONS
// ─────────────────────────────────────────────
let calYear, calMonth, calSelected = '';

function initCalendar() {
  calSelected = '';
  const tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + MIN_BOOKING_DAYS);
  calYear  = tomorrow.getFullYear();
  calMonth = tomorrow.getMonth();
  document.getElementById('preferredDay').value = '';
  if (document.getElementById('date-error')) document.getElementById('date-error').style.display = 'none';
  renderCalendar();
}

function renderCalendar() {
  const today    = new Date(); today.setHours(0,0,0,0);
  const tomorrow = new Date(today); tomorrow.setDate(today.getDate() + MIN_BOOKING_DAYS);
  const maxDate  = new Date(today); maxDate.setDate(today.getDate() + MAX_BOOKING_DAYS);
  const MONTHS   = ['January','February','March','April','May','June','July','August','September','October','November','December'];

  document.getElementById('calMonthLabel').textContent = `${MONTHS[calMonth]} ${calYear}`;

  const firstOfMonth = new Date(calYear, calMonth, 1);
  const lastOfMonth  = new Date(calYear, calMonth + 1, 0);
  document.getElementById('calPrev').disabled = firstOfMonth <= tomorrow;
  document.getElementById('calNext').disabled = lastOfMonth  >= maxDate;

  const grid = document.getElementById('calGrid');
  grid.innerHTML = '';

  // Empty leading cells
  const startDay = firstOfMonth.getDay(); // 0=Sun
  for (let i = 0; i < startDay; i++) {
    const el = document.createElement('div');
    el.className = 'cal-cell empty';
    el.setAttribute('role','gridcell');
    el.setAttribute('aria-disabled','true');
    grid.appendChild(el);
  }

  const daysInMonth = lastOfMonth.getDate();
  for (let d = 1; d <= daysInMonth; d++) {
    const date    = new Date(calYear, calMonth, d);
    const dateStr = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dateLabel = date.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
    const dow     = date.getDay();
    const isWknd  = (dow === 0);  // Block Sundays
    const isPast  = date < tomorrow;
    const isFar   = date > maxDate;
    const isBlock = BLOCKED_DATES.has(dateStr);
    const isSel   = dateStr === calSelected;

    const el = document.createElement('div');
    el.textContent = d;
    el.setAttribute('role','gridcell');
    el.setAttribute('data-date', dateStr);

    if (isSel) {
      el.className = 'cal-cell selected';
      el.setAttribute('tabindex','0');
      el.setAttribute('aria-selected','true');
      el.setAttribute('aria-label','Selected: ' + dateLabel);
      el.onclick = () => pickDate(dateStr);
      el.onkeydown = (e) => calKeyHandler(e, dateStr, 'main');
    } else if (isPast || isFar) {
      el.className = 'cal-cell disabled';
      el.setAttribute('aria-disabled','true');
      el.setAttribute('aria-label', dateLabel + ' — unavailable');
    } else if (isBlock) {
      el.className = 'cal-cell blocked';
      el.setAttribute('aria-disabled','true');
      el.setAttribute('aria-label', dateLabel + ' — unavailable');
    } else if (isWknd) {
      el.className = 'cal-cell wknd-cell disabled';
      el.setAttribute('aria-disabled','true');
      el.setAttribute('aria-label', dateLabel + ' — unavailable');
    } else {
      el.className = 'cal-cell available';
      el.setAttribute('tabindex','0');
      el.setAttribute('aria-selected','false');
      el.setAttribute('aria-label', dateLabel);
      el.onclick = () => pickDate(dateStr);
      el.onkeydown = (e) => calKeyHandler(e, dateStr, 'main');
    }
    grid.appendChild(el);
  }

  // Selected label
  const picked = document.getElementById('calPicked');
  if (calSelected) {
    picked.textContent = new Date(calSelected + 'T12:00:00').toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' });
    picked.classList.remove('none');
  } else {
    picked.textContent = 'Select a date above';
    picked.classList.add('none');
  }
}

function pickDate(dateStr) {
  calSelected = dateStr;
  document.getElementById('preferredDay').value = dateStr;
  if (document.getElementById('date-error')) document.getElementById('date-error').style.display = 'none';
  renderCalendar();
}

function calPrevMonth() {
  calMonth--;
  if (calMonth < 0) { calMonth = 11; calYear--; }
  renderCalendar();
}

function calNextMonth() {
  calMonth++;
  if (calMonth > 11) { calMonth = 0; calYear++; }
  renderCalendar();
}

