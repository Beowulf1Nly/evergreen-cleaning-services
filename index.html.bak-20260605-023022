      el.onclick = () => qPickDate(dateStr);
      el.onkeydown = (e) => calKeyHandler(e, dateStr, 'q');
    } else if (isPast||isFar) {
      el.className='cal-cell disabled';
      el.setAttribute('aria-disabled','true');
      el.setAttribute('aria-label', dateLabel + ' — unavailable');
    } else if (isBlock) {
      el.className='cal-cell blocked';
      el.setAttribute('aria-disabled','true');
      el.setAttribute('aria-label', dateLabel + ' — unavailable');
    } else if (isWknd) {
      el.className='cal-cell wknd-cell disabled';
      el.setAttribute('aria-disabled','true');
      el.setAttribute('aria-label', dateLabel + ' — unavailable');
    } else {
      el.className='cal-cell available';
      el.setAttribute('tabindex','0');
      el.setAttribute('aria-selected','false');
      el.setAttribute('aria-label', dateLabel);
      el.onclick = () => qPickDate(dateStr);
      el.onkeydown = (e) => calKeyHandler(e, dateStr, 'q');
    }
    grid.appendChild(el);
  }
  const picked = document.getElementById('qCalPicked');
  if (qCalSelected) {
    picked.textContent = new Date(qCalSelected+'T12:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'});
    picked.classList.remove('none');
  } else {
    picked.textContent = 'Select a date above';
    picked.classList.add('none');
  }
}

function qPickDate(dateStr) {
