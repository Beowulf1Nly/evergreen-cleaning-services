<style>
  :root {
    --green-deep: #1a3a1a;
    --green-mid: #2d6a2d;
    --green-bright: #4caf50;
    --green-light: #7ec87e;
    --green-pale: #e8f5e9;
    --cream: #faf9f6;
    --earth: #5c4a2a;
    --gold: #c9a84c;
    --white: #ffffff;
    --text: #1a1a1a;
    --text-muted: #6b7280;
    --border: #e5e7eb;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text);
    overflow-x: hidden;
  }

  /* ── SITE HEADER WRAPPER ── */
  #siteHeader {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 400;
  }

  /* ── NAV ── */
  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 60px;
    background: rgba(250,249,246,0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(26,58,26,0.07);
    transition: box-shadow .3s, padding .3s;
  }
  nav.scrolled {
    box-shadow: 0 2px 20px rgba(0,0,0,0.08);
    padding: 13px 60px;
  }
  .nav-logo img { height: 52px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.15)); }
  .nav-right { flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 32px; }
  .nav-links { display: flex; align-items: center; gap: 36px; list-style: none; }
  .nav-links a {
    text-decoration: none;
    font-size: 14px; font-weight: 500; letter-spacing: .03em;
    color: var(--green-deep);
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--green-bright); }
  .nav-account {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 14px; font-weight: 500; letter-spacing: .02em;
    color: var(--green-deep) !important;
    background: transparent;
    border: 1.5px solid rgba(26,58,26,0.2);
    padding: 9px 20px; border-radius: 6px;
    text-decoration: none;
    transition: background .2s, border-color .2s !important;
  }
  .nav-account:hover {
    background: var(--green-pale) !important;
    border-color: var(--green-mid) !important;
    color: var(--green-deep) !important;
  }
  .nav-account-icon { font-size: 15px; line-height: 1; }
  .nav-cta {
    background: var(--green-mid);
    color: #fff !important;
    padding: 10px 24px;
    border-radius: 6px;
    transition: background .2s !important;
  }
  .nav-cta:hover { background: var(--green-deep) !important; color: #fff !important; }

  /* ── HERO — split design ── */
  .hero {
    display: flex; align-items: stretch;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    padding: 0;
    gap: 0;
  }
  /* Left dark panel */
  .hero-bg {
    position: absolute; inset: 0;
    background: var(--cream);
    z-index: 0;
  }
  .hero-left {
    position: relative; z-index: 2;
    flex: 0 0 42%;
    display: flex; flex-direction: column; justify-content: center;
    padding: 120px 56px 60px 60px;
    background: linear-gradient(155deg, #071510 0%, #0d2410 25%, #1a3a1a 55%, #1f3f20 80%, #162e18 100%);
    overflow: hidden;
  }
  /* Subtle dot grid texture */
  .hero-left::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(76,175,80,.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
    animation: gridDrift 20s linear infinite;
  }
  @keyframes gridDrift {
    0%   { background-position: 0 0; }
    100% { background-position: 28px 28px; }
  }
  /* Bottom-left ambient glow — floats slowly */
  .hero-left::after {
    content: '';
    position: absolute; bottom: -15%; left: -15%;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(76,175,80,0.13) 0%, transparent 65%);
    pointer-events: none;
    animation: orbDrift 12s ease-in-out infinite;
  }
  @keyframes orbDrift {
    0%,100% { transform: translate(0, 0) scale(1); }
    33%     { transform: translate(30px, -25px) scale(1.08); }
    66%     { transform: translate(-15px, -40px) scale(0.95); }
  }
  /* Top-right accent glow */
  .hero-glow-tr {
    position: absolute; top: -20%; right: -20%;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(76,175,80,0.09) 0%, transparent 65%);
    pointer-events: none;
    animation: orbDrift 16s 4s ease-in-out infinite reverse;
  }
  /* Diagonal accent line */
  .hero-accent-line {
    position: absolute; top: 0; right: 56px;
    width: 1px; height: 100%;
    background: linear-gradient(to bottom, transparent, rgba(76,175,80,0.12) 30%, rgba(76,175,80,0.08) 70%, transparent);
    pointer-events: none;
  }
  /* Right light panel */
  .hero-right {
    flex: 1;
    display: flex; align-items: center; justify-content: center;
    position: relative; z-index: 1;
    background: #ffffff;
    overflow: hidden;
  }
  .hero-right::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(26,58,26,0.18) 0%, transparent 40%);
    z-index: 3;
  }
  .hero-ring { display: none; }

  /* Floating trust cards */
  .hero-float-card {
    position: absolute;
    background: #fff;
    border: 1px solid rgba(45,106,45,0.1);
    border-radius: 14px;
    padding: 14px 18px;
    display: flex; align-items: center; gap: 12px;
    box-shadow: 0 4px 20px rgba(26,58,26,0.1), 0 1px 4px rgba(26,58,26,0.06);
    z-index: 3;
    animation: fadeIn .8s ease both;
    white-space: nowrap;
  }
  .hero-float-card .fc-icon {
    width: 38px; height: 38px;
    border-radius: 10px;
    background: var(--green-pale);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .hero-float-card .fc-label {
    font-size: 11px; color: var(--text-muted);
    font-weight: 500; letter-spacing: .03em;
    text-transform: uppercase; line-height: 1;
    margin-bottom: 3px;
  }
  .hero-float-card .fc-value {
    font-size: 15px; font-weight: 700;
    color: var(--green-deep); line-height: 1;
  }
  .fc-top    { top: 18%; left: 6%; animation-delay: .5s; }
  .fc-mid    { bottom: 28%; right: 5%; animation-delay: .65s; }
  .fc-bottom { bottom: 13%; left: 8%; animation-delay: .8s; }
  .hero-grass { display: none; }
  .hero-circle-1, .hero-circle-2, .hero-glow { display: none; }

  /* Content inside left panel */
  .hero-content {
    position: relative; z-index: 2;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(76,175,80,0.15);
    border: 1px solid rgba(76,175,80,0.25);
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 13px; font-weight: 500;
    color: #7ec87e;
    margin-bottom: 28px;
    animation: fadeUp .6s ease both;
  }
  .hero-badge::before {
    content: '';
    width: 7px; height: 7px;
    background: #4caf50;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 0 0 rgba(76,175,80,.5);
    animation: ring 2s infinite;
  }
  @keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50% { opacity:.6; transform:scale(1.3); }
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(44px, 4.5vw, 70px);
    font-weight: 900;
    line-height: 1.07;
    color: #ffffff;
    margin-bottom: 20px;
    animation: fadeUp .7s .1s ease both;
    letter-spacing: -.02em;
  }
  .hero h1 em {
    font-style: normal;
    color: #6dce74;
  }
  .hero p {
    font-size: 16px; line-height: 1.8;
    color: rgba(255,255,255,0.6);
    margin-bottom: 36px;
    max-width: 420px;
    animation: fadeUp .7s .2s ease both;
  }
  .hero-btns {
    display: flex; gap: 12px; flex-wrap: wrap;
    animation: fadeUp .7s .3s ease both;
  }
  .btn-primary {
    background: #4caf50;
    color: #fff;
    padding: 15px 32px;
    border-radius: 8px;
    font-size: 15px; font-weight: 600;
    text-decoration: none;
    border: none; cursor: pointer;
    transition: background .2s, transform .15s, box-shadow .2s;
    display: inline-block;
    box-shadow: 0 4px 18px rgba(76,175,80,0.35);
  }
  .btn-primary:hover {
    background: #43a047;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(76,175,80,0.45);
  }
  .btn-secondary {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.85);
    padding: 15px 32px;
    border-radius: 8px;
    font-size: 15px; font-weight: 600;
    text-decoration: none;
    border: 1.5px solid rgba(255,255,255,0.18);
    cursor: pointer;
    transition: all .2s;
    display: inline-block;
  }
  .btn-secondary:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.35);
    transform: translateY(-2px);
  }

  .hero-pay-note { font-size: 13px; color: rgba(255,255,255,0.72); margin-top: 12px; }
  .hero-pay-note strong { color: rgba(255,255,255,0.95); }

  .hero-stats {
    display: flex; gap: 40px;
    margin-top: 48px;
    padding-top: 28px;
    border-top: 1px solid rgba(255,255,255,0.12);
    animation: fadeUp .7s .4s ease both;
  }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 36px; font-weight: 700;
    color: #ffffff;
  }
  .stat-label { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 3px; letter-spacing: .02em; }

  /* ── SERVICES ── */
  .services {
    padding: 100px 60px;
    background: var(--white);
  }
  .section-label {
    text-align: center;
    font-size: 13px; font-weight: 600; letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--green-bright);
    margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 3.5vw, 48px);
    font-weight: 700;
    text-align: center;
    color: var(--green-deep);
    margin-bottom: 16px;
  }
  .section-sub {
    text-align: center;
    font-size: 17px;
    color: var(--text-muted);
    max-width: 520px;
    margin: 0 auto 64px;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .service-card {
    border: 1px solid rgba(26,58,26,0.1);
    border-radius: 16px;
    padding: 40px 36px;
    background: var(--cream);
    transition: transform .2s, box-shadow .2s, border-color .2s;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .service-card .btn-book {
    margin-top: auto;
  }
  .service-card:hover {
    transform: translateY(-4px);
