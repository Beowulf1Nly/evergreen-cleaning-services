function nextSlide() {
  currentSlide = (currentSlide + 1) % carouselData.images.length;
  updateCarousel();
  resetAutoPlay();
}

function prevSlide() {
  currentSlide = (currentSlide - 1 + carouselData.images.length) % carouselData.images.length;
  updateCarousel();
  resetAutoPlay();
}

function goToSlide(idx) {
  currentSlide = idx;
  updateCarousel();
  resetAutoPlay();
}

function updateCarousel() {
  const track = document.getElementById('carouselTrack');
  track.style.transform = `translateX(-${currentSlide * 100}%)`;

  // Update dots
  document.querySelectorAll('.carousel-dot').forEach((dot, idx) => {
    dot.classList.toggle('active', idx === currentSlide);
  });
}

function startAutoPlay() {
  carouselInterval = setInterval(() => {
    currentSlide = (currentSlide + 1) % carouselData.images.length;
    updateCarousel();
  }, 5000); // Change slide every 5 seconds
}

function resetAutoPlay() {
  clearInterval(carouselInterval);
  startAutoPlay();
}

// Render testimonials from data.json
function renderTestimonials() {
  const container = document.getElementById('testimonialsContainer');
  if (!container) return; // element not present on this page

  if (!carouselData.reviews || carouselData.reviews.length === 0) {
    container.innerHTML = '<div style="text-align:center; padding:40px; color:#999;">No reviews yet. Add reviews to data.json</div>';
    return;
  }

  container.innerHTML = carouselData.reviews.map((r, i) => `
    <div class="testimonial-card reveal" style="transition-delay:${i * 0.1}s">
      <div class="testimonial-stars">${'★'.repeat(r.stars)}${'☆'.repeat(5-r.stars)}</div>
      <div class="testimonial-text">"${r.text}"</div>
      <div class="testimonial-author">${r.name}</div>
      <div class="testimonial-location">${r.location}</div>
    </div>
  `).join('');
  // Re-observe newly rendered cards
  document.querySelectorAll('.testimonial-card.reveal:not(.visible)').forEach(el => {
    const io2 = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) { entry.target.classList.add('visible'); io2.unobserve(entry.target); }
      });
    }, { threshold: 0.12 });
    io2.observe(el);
  });
}

