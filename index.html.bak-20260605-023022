  .carousel-container {
    position: relative;
    max-width: 800px;
    margin: 0 auto 80px;
    background: var(--cream);
    border-radius: 16px;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    transition: transform .5s ease;
  }

  .carousel-slide {
    min-width: 100%;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e8e8;
  }

  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .carousel-controls {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 10;
  }

  .carousel-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    cursor: pointer;
    transition: all .2s;
    border: 2px solid transparent;
  }

  .carousel-dot.active {
    background: #fff;
    border-color: var(--green-mid);
  }

  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    background: rgba(26,58,26,0.7);
    border: none;
    color: #fff;
    font-size: 24px;
    cursor: pointer;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .2s;
    z-index: 10;
  }

  .carousel-arrow:hover {
    background: rgba(26,58,26,0.9);
  }

  .carousel-arrow.prev {
    left: 16px;
  }

  .carousel-arrow.next {
    right: 16px;
  }

  .testimonials {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 28px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .testimonial-card {
    background: var(--cream);
    border: 1px solid rgba(26,58,26,0.1);
    border-radius: 16px;
    padding: 32px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .testimonial-card::before {
    content: '"';
    position: absolute;
    top: -10px;
    left: 20px;
    font-size: 80px;
    opacity: 0.1;
    font-family: 'Playfair Display', serif;
    color: var(--green-mid);
  }

  .testimonial-stars {
    font-size: 16px;
    color: #ffd700;
    margin-bottom: 12px;
  }

  .testimonial-text {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 20px;
    flex: 1;
  }

  .testimonial-author {
    font-weight: 600;
    color: var(--green-deep);
    margin-bottom: 4px;
  }

  .testimonial-location {
    font-size: 13px;
    color: var(--text-muted);
  }

  .review-count-badge {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 2px;
    margin-bottom: 32px;
  }

  .edit-gallery-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 24px;
    background: var(--green-mid);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background .2s;
  }

  .edit-gallery-btn:hover {
    background: var(--green-deep);
  }

  /* ── BOOKING MODAL ── */
  .modal-overlay {
    display: none;
    position: fixed; inset: 0; z-index: 400;
    background: rgba(26,58,26,0.5);
    backdrop-filter: blur(4px);
    align-items: center; justify-content: center;
    padding: 20px;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: #fff;
    border-radius: 20px;
    padding: 48px;
    max-width: 520px; width: 100%;
    max-height: 90vh; overflow-y: auto;
    position: relative;
    animation: modalIn .3s ease both;
  }
  @keyframes modalIn {
    from { opacity:0; transform: scale(.95) translateY(10px); }
    to   { opacity:1; transform: scale(1) translateY(0); }
  }
  .modal-close {
    position: absolute; top: 20px; right: 20px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--green-pale);
    cursor: pointer;
    font-size: 18px;
    display: flex; align-items: center; justify-content: center;
    color: var(--green-deep);
    transition: background .2s;
  }
  .modal-close:hover { background: #d5ecd5; }
  /* ── Exit Intent Popup ───────────────────────────────────────── */
  #exitPopupOverlay {
    display: none;
    position: fixed; inset: 0; z-index: 900;
    background: rgba(15,30,15,0.55);
    backdrop-filter: blur(6px);
    align-items: center; justify-content: center;
    padding: 20px;
  }
  #exitPopupOverlay.open { display: flex; }
  #exitPopup {
    background: #fff;
    border-radius: 20px;
    padding: 0;
    max-width: 420px; width: 100%;
    position: relative;
    overflow: hidden;
    animation: modalIn .28s ease both;
    box-shadow: 0 20px 60px rgba(0,0,0,0.22);
  }
  #exitPopup .ep-band {
    background: linear-gradient(160deg, #1e3d1e 0%, #2d5a2d 100%);
    padding: 32px 36px 28px;
    text-align: center;
    position: relative;
  }
  #exitPopup .ep-badge {
    display: inline-flex; align-items: center; gap: 5px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.22);
    color: rgba(255,255,255,0.9);
    font-size: 10px; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase;
    padding: 5px 12px; border-radius: 20px;
    margin-bottom: 16px;
  }
  #exitPopup .ep-price {
    font-family: 'Playfair Display', serif;
    font-size: 72px; font-weight: 900; line-height: 1;
    color: #fff;
    letter-spacing: -.03em;
  }
  #exitPopup .ep-price sup {
    font-size: 30px; vertical-align: super; font-weight: 700;
    letter-spacing: 0; opacity: .85;
  }
  #exitPopup .ep-price-label {
    font-size: 12.5px; color: rgba(255,255,255,0.6);
    margin-top: 6px; letter-spacing: .02em;
  }
  #exitPopup .ep-body {
    padding: 24px 30px 26px;
    text-align: center;
    border-top: 1px solid #f0f0f0;
  }
  #exitPopup .ep-headline {
    font-family: 'Playfair Display', serif;
    font-size: 20px; font-weight: 700;
    color: var(--green-deep);
    line-height: 1.3;
    margin-bottom: 8px;
  }
  #exitPopup .ep-sub {
    font-size: 13.5px; color: var(--text-muted);
    line-height: 1.65; margin-bottom: 20px;
    max-width: 320px; margin-left: auto; margin-right: auto;
  }
  #exitPopup .ep-cta {
    display: block; width: 100%;
    background: var(--green-mid);
    color: #fff;
    font-size: 15px; font-weight: 600;
    padding: 14px 24px;
    border: none; border-radius: 10px;
    cursor: pointer;
    letter-spacing: .01em;
    transition: background .18s, transform .15s;
    margin-bottom: 10px;
  }
  #exitPopup .ep-cta:hover {
    background: var(--green-deep); transform: translateY(-1px);
  }
  #exitPopup .ep-dismiss {
    font-size: 11.5px; color: #aaa;
    cursor: pointer; background: none; border: none;
    text-decoration: none;
    padding: 2px 0;
    transition: color .15s;
  }
  #exitPopup .ep-dismiss:hover { color: #666; }
  #exitPopup .ep-close {
    position: absolute; top: 12px; right: 12px;
    width: 28px; height: 28px; border-radius: 50%;
    background: rgba(255,255,255,0.14);
    border: none; cursor: pointer;
    font-size: 14px; color: rgba(255,255,255,0.7);
    display: flex; align-items: center; justify-content: center;
    transition: background .18s, color .18s;
  }
  #exitPopup .ep-close:hover { background: rgba(255,255,255,0.25); color:#fff; }
  #exitPopup .ep-trust {
    display: flex; justify-content: center; gap: 14px;
    flex-wrap: wrap; margin-bottom: 18px;
    font-size: 11.5px; color: #888;
  }
  #exitPopup .ep-trust span { display: flex; align-items: center; gap: 3px; }

  .modal h2 {
    font-family: 'Playfair Display', serif;
    font-size: 26px; font-weight: 700;
    color: var(--green-deep);
    margin-bottom: 6px;
  }
  .modal-service-name {
    font-size: 14px; color: var(--green-bright); font-weight: 600;
    margin-bottom: 28px;
  }
  .form-row { margin-bottom: 18px; }
  .form-row label {
    display: block;
    font-size: 13px; font-weight: 600;
    color: var(--green-deep);
    margin-bottom: 7px;
    letter-spacing: .02em;
  }
  .form-row input,
  .form-row select,
  .form-row textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid rgba(26,58,26,0.15);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--text);
    background: var(--cream);
    outline: none;
    transition: border-color .2s;
  }
  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus { border-color: var(--green-bright); }
  .form-row textarea { height: 80px; resize: vertical; }

  .frequency-toggle {
    display: flex; gap: 10px;
    margin-bottom: 24px;
  }
  .freq-btn {
    flex: 1;
    padding: 12px;
    border-radius: 8px;
    border: 1.5px solid rgba(26,58,26,0.15);
    background: var(--cream);
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; font-weight: 600;
    color: var(--text-muted);
    transition: all .2s;
    text-align: center;
  }
  .freq-btn.active {
    border-color: var(--green-bright);
    background: var(--green-pale);
    color: var(--green-deep);
  }

  #card-element {
    padding: 14px 16px;
    border: 1.5px solid rgba(26,58,26,0.15);
    border-radius: 8px;
    background: var(--cream);
    transition: border-color .2s;
  }
  #card-element.StripeElement--focus { border-color: var(--green-bright); }
  #card-errors {
    color: #e53e3e; font-size: 13px;
    margin-top: 8px; min-height: 18px;
  }

  .price-summary {
    background: var(--green-pale);
    border-radius: 10px;
    padding: 16px 20px;
    margin: 20px 0;
    display: flex; justify-content: space-between; align-items: center;
  }
  .price-summary .label { font-size: 14px; color: var(--text-muted); }
  .price-summary .amount {
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 700;
    color: var(--green-deep);
  }
  .price-summary .freq-label {
    font-size: 12px; color: var(--green-mid); font-weight: 500;
  }

  .btn-pay {
    width: 100%; padding: 16px;
    background: var(--green-mid);
    color: #fff; border: none;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 16px; font-weight: 600;
    cursor: pointer;
    transition: background .2s, transform .15s;
    display: flex; align-items: center; justify-content: center; gap: 10px;
  }
  .btn-pay:hover { background: var(--green-deep); transform: translateY(-1px); }
  .btn-pay:disabled { background: #ccc; cursor: not-allowed; transform: none; }
  .btn-pay .spinner {
    width: 18px; height: 18px;
    border: 2px solid rgba(255,255,255,0.4);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin .7s linear infinite;
    display: none;
  }
  .btn-pay.loading .spinner { display: block; }
  .btn-pay.loading .pay-text { display: none; }

  @keyframes spin { to { transform: rotate(360deg); } }

  .stripe-note {
    text-align: center; font-size: 12px; color: var(--text-muted);
    margin-top: 14px;
    display: flex; align-items: center; justify-content: center; gap: 6px;
  }
  .stripe-note svg { width: 14px; height: 14px; opacity: .5; }

  /* ── SUCCESS STATE ── */
  .success-state {
    display: none;
    text-align: center;
    padding: 20px 0;
  }
  .success-icon {
    width: 72px; height: 72px;
    background: var(--green-pale);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 32px;
    margin: 0 auto 20px;
  }
  .success-state h3 {
    font-family: 'Playfair Display', serif;
    font-size: 24px; font-weight: 700;
    color: var(--green-deep);
    margin-bottom: 10px;
  }
  .success-state p { font-size: 15px; color: var(--text-muted); line-height: 1.7; }

  /* ── FOOTER ── */
  footer {
    background: var(--green-deep);
    color: rgba(255,255,255,0.7);
    padding: 48px 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 32px;
    border-top: 3px solid var(--green-mid);
  }
  .footer-brand-text {
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 700;
    color: #fff; margin-bottom: 6px;
  }
  .footer-brand-text span { color: var(--green-light); }
  .footer-tagline { font-size: 13px; color: rgba(255,255,255,0.45); }
  .footer-links {
    display: flex; gap: 24px; flex-wrap: wrap; list-style: none;
  }
  .footer-links a {
    color: rgba(255,255,255,0.65);
    text-decoration: none; font-size: 14px;
    transition: color .2s;
  }
  .footer-links a:hover { color: var(--green-light); }
  .footer-contact-info { text-align: right; }
  .footer-contact-info a {
    display: block;
    color: var(--green-light);
    text-decoration: none; font-size: 14px;
    margin-bottom: 6px; transition: color .2s;
  }
  .footer-contact-info a:hover { color: #fff; }
  .footer-copy {
    width: 100%; text-align: center;
    font-size: 12px; color: rgba(255,255,255,0.3);
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  /* ── BOOKING CALENDAR ── */
  .cal-widget { border:1.5px solid rgba(26,58,26,0.15); border-radius:10px; overflow:hidden; background:#fff; margin-bottom:4px; }
  .cal-header { display:flex; align-items:center; justify-content:space-between; padding:10px 14px; background:var(--green-pale); }
  .cal-month-label { font-weight:700; font-size:14px; color:var(--green-deep); letter-spacing:.01em; }
  .cal-nav { background:none; border:none; font-size:22px; line-height:1; cursor:pointer; color:var(--green-mid); padding:2px 8px; border-radius:6px; transition:background .15s; }
  .cal-nav:hover:not(:disabled) { background:rgba(45,106,45,0.12); }
  .cal-nav:disabled { color:#ccc; cursor:not-allowed; }
  .cal-day-names { display:grid; grid-template-columns:repeat(7,1fr); padding:8px 8px 0; border-bottom:1px solid rgba(26,58,26,0.07); }
  .cal-day-name { text-align:center; font-size:11px; font-weight:700; color:var(--text-muted); letter-spacing:.06em; padding-bottom:8px; }
  .cal-day-name.wknd { color:#d1d5db; }
  .cal-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:3px; padding:8px; }
  .cal-cell { aspect-ratio:1; display:flex; align-items:center; justify-content:center; border-radius:8px; font-size:13px; font-weight:500; transition:background .15s, color .15s; }
  .cal-cell.available { color:var(--green-deep); cursor:pointer; }
  .cal-cell.available:hover { background:var(--green-pale); }
  .cal-cell.selected { background:var(--green-mid) !important; color:#fff !important; font-weight:700; cursor:pointer; }
  .cal-cell.disabled, .cal-cell.wknd-cell, .cal-cell.blocked { color:#d1d5db; cursor:not-allowed; }
  .cal-cell.blocked { text-decoration:line-through; }
  .cal-cell.empty { cursor:default; }
  .cal-picked { padding:10px 14px; border-top:1px solid rgba(26,58,26,0.08); font-size:13px; font-weight:600; color:var(--green-mid); text-align:center; min-height:40px; display:flex; align-items:center; justify-content:center; }
  .cal-picked.none { color:var(--text-muted); font-weight:400; }

  /* ── PROMO BANNER ── */
  #promoBanner {
    background: var(--green-deep);
    color: rgba(255,255,255,.85);
    text-align: center;
    padding: 9px 48px;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: .01em;
    display: none;
    white-space: nowrap;
    overflow: hidden;
    position: relative;
  }
  #promoBanner a {
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: opacity .2s;
  }
  #promoBanner a:hover { opacity: .8; }
  #promoBanner .banner-claim {
    background: none;
    border: 1px solid rgba(255,255,255,.35);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 12px;
    border-radius: 5px;
    letter-spacing: .02em;
    flex-shrink: 0;
    transition: border-color .2s;
  }
  #promoBanner a:hover .banner-claim { border-color: rgba(255,255,255,.7); }
  #promoBanner .banner-close {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255,255,255,0.6);
    font-size: 18px;
    cursor: pointer;
    line-height: 1;
    padding: 4px 8px;
    transition: color .2s;
  }
  #promoBanner .banner-close:hover { color: #fff; }
  @media (max-width: 600px) {
    #promoBanner { white-space: normal; padding: 8px 44px; font-size: 12px; }
    #promoBanner .banner-claim { display: none; }
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity:0; transform: translateY(20px); }
    to   { opacity:1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity:0; }
    to   { opacity:1; }
  }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(48px);
    transition: opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1);
  }
  .reveal-left.visible { opacity:1; transform:translateX(0); }
  .reveal-right {
    opacity: 0;
    transform: translateX(60px);
    transition: opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1);
  }
  .reveal-right.visible { opacity:1; transform:translateX(0); }

  /* ── ANIMATE-UP (used in reviews / CTA / FAQ) ── */
  .animate-up {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity .65s cubic-bezier(.16,1,.3,1), transform .65s cubic-bezier(.16,1,.3,1);
  }
  .animate-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── HERO PARTICLES ── */
  #heroParticles {
    position: absolute; inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }
  .particle {
    position: absolute;
    border-radius: 50%;
    background: #4caf50;
    opacity: 0;
    animation: floatParticle var(--dur, 6s) var(--delay, 0s) ease-in-out infinite;
  }
  @keyframes floatParticle {
    0%   { opacity:0; transform: translateY(0) scale(0); }
    10%  { opacity: var(--max-op, .15); transform: translateY(-10px) scale(1); }
    90%  { opacity: var(--max-op, .15); }
    100% { opacity:0; transform: translateY(calc(-1 * var(--rise, 80px))) scale(0.5); }
  }

  /* ── 3D CARD TILT ── */
  .service-card {
    transform-style: preserve-3d;
    will-change: transform;
    transition: transform .15s ease, box-shadow .2s, border-color .2s !important;
  }
  .service-card:hover {
    box-shadow: 0 24px 60px rgba(45,106,45,0.18) !important;
    border-color: var(--green-bright) !important;
  }

  /* ── STAT COUNTER ── */
  .stat-num {
    transition: color .3s;
  }
  .stat-num.counting { color: var(--green-bright); }

  /* ── SECTION CONNECTOR ── */
  .section-divider {
    width: 60px; height: 3px;
    background: linear-gradient(90deg, var(--green-bright), var(--green-mid));
    border-radius: 2px;
    margin: 0 auto 20px;
  }

  /* ── STEP ENHANCED ── */
  .step-num {
    transition: transform .3s, box-shadow .3s;
  }
  .step:hover .step-num {
    transform: scale(1.12) translateY(-4px);
    box-shadow: 0 16px 32px rgba(45,106,45,0.3);
  }

  /* ── SHIMMER on featured card ── */
  .service-card.featured::after {
    content: '';
    position: absolute;
    top: -50%; left: -60%;
    width: 40%; height: 200%;
    background: linear-gradient(105deg, transparent, rgba(255,255,255,.07), transparent);
    transform: rotate(25deg);
    animation: shimmer 4s 2s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes shimmer {
    0%   { left: -60%; opacity: 0; }
    10%  { opacity: 1; }
    40%  { left: 140%; opacity: 0; }
    100% { left: 140%; opacity: 0; }
  }

  /* ── ENHANCED hero badge pulse ring ── */
  .hero-badge::before {
    box-shadow: 0 0 0 0 rgba(76,175,80,.5);
    animation: pulse 2s infinite, ring 2s infinite;
  }
  @keyframes ring {
    0%  { box-shadow: 0 0 0 0 rgba(76,175,80,.5); }
    70% { box-shadow: 0 0 0 8px rgba(76,175,80,0); }
