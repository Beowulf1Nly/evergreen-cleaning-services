    // Lookup still in flight — show a neutral state, never flash an error
    if (sublabel) sublabel.textContent = 'Detecting your yard size…';
    if (manual) manual.style.display = 'none';
    if (personalLink) personalLink.style.display = 'none';
  } else if (isXL) {
