}
function qCalPrevMonth() { qCalMonth--; if(qCalMonth<0){qCalMonth=11;qCalYear--;} renderQCal(); }
function qCalNextMonth() { qCalMonth++; if(qCalMonth>11){qCalMonth=0;qCalYear++;} renderQCal(); }

// ── Keyboard navigation for all calendars ──
// calType: 'q' = quote modal calendar, 'main' = booking modal calendar
function calKeyHandler(e, dateStr, calType) {
  const KEYS = { Enter:13, Space:32, Left:37, Up:38, Right:39, Down:40 };
  if (![13,32,37,38,39,40].includes(e.keyCode)) return;
  e.preventDefault();

  // Enter / Space — select the date
  if (e.keyCode === 13 || e.keyCode === 32) {
    if (calType === 'q') qPickDate(dateStr);
    else pickDate(dateStr);
    return;
  }

  // Arrow keys — navigate to adjacent available date
  const offsets = { 37:-1, 39:1, 38:-7, 40:7 }; // Left, Right, Up (1 week back), Down (1 week ahead)
  const delta = offsets[e.keyCode];
  const today = new Date(); today.setHours(0,0,0,0);
  const earliest = new Date(today); earliest.setDate(today.getDate() + MIN_BOOKING_DAYS);
  const maxDate  = new Date(today); maxDate.setDate(today.getDate() + MAX_BOOKING_DAYS);

  let cur = new Date(dateStr + 'T12:00:00');
  let attempts = 0;
  do {
    cur.setDate(cur.getDate() + delta);
    attempts++;
    if (cur < earliest || cur > maxDate) return; // out of range, stop
  } while (
    BLOCKED_DATES.has(cur.toISOString().slice(0,10)) && attempts < 14
  );

  const targetStr = cur.toISOString().slice(0,10);
  // Find the cell in the grid and focus it; if it's in a different month, navigate there first
  if (calType === 'q') {
    if (cur.getMonth() !== qCalMonth || cur.getFullYear() !== qCalYear) {
      qCalMonth = cur.getMonth(); qCalYear = cur.getFullYear(); renderQCal();
    }
  } else {
    if (cur.getMonth() !== calMonth || cur.getFullYear() !== calYear) {
      calMonth = cur.getMonth(); calYear = cur.getFullYear(); renderCalendar();
    }
  }
  const gridId = calType === 'q' ? 'qCalGrid' : 'calGrid';
  const target = document.querySelector(`#${gridId} [data-date="${targetStr}"]`);
  if (target && target.getAttribute('tabindex') === '0') target.focus();
}

